@using MedApp.Models
@using MedApp.Models.Viral

<div class="d-flex flex-column gap-5">
    <Entry Title="@Title"
           Value="@AttributeNumeric.Value"/>

    <Dropdown Title="@UnitTitle"
              Items="@AttributeNumeric.Units"
              Selected="@AttributeNumeric.SelectedUnit"/>
</div>

@code {

    [Parameter]
    public ViralAttributeNumeric AttributeNumeric { get; set; }
    
    [Parameter]
    public string Title { get; set; }
    
    [Parameter]
    public string UnitTitle { get; set; }

}