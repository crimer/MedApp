<MudNumericField ValueChanged="@OnChange"
                 Label="@Title" 
                 T="double"
                 Variant="Variant.Outlined"/>

@code {
    [Parameter]
    public double Value { get; set; }

    [Parameter]
    public string Title { get; set; }
    
    [Parameter]
    public EventCallback<double> OnChange { get; set; }
}